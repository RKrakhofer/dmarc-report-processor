# IMAP-Zugangsdaten
IMAP_HOST=mail.domain.com
IMAP_PORT=993
IMAP_USER=dmarc@domain.com
IMAP_PASSWORD=geheimes-passwort

# Eigene Domains für den Report, kommagetrennt (wird in dmarc_report.py verwendet)
MY_DOMAINS=domain.com,domain2.com

# IMAP-Ordner, kommagetrennte Liste (optional, Standard: INBOX)
IMAP_FOLDER=INBOX
# Beispiel mehrere Ordner:
# IMAP_FOLDER=INBOX,DMARC,Junk

# Papierkorb-Ordner für Batch-Duplikate (optional, Standard: Trash)
# Batch-Duplikate = identische Message-ID mehrfach in einer Runde (z.B. Google-Doppelzustellung)
TRASH_FOLDER=Trash

# Pfad zur SQLite-Datenbank (optional, Standard: dmarc_reports.db)
DB_PATH=dmarc_reports.db

# ---------------------------------------------------------------------------
# Exchange Online (Microsoft Graph API) – nur für --xchg
# ---------------------------------------------------------------------------
# Azure AD App Registration: App-Only (Client Credentials)
# Benötigte API-Berechtigung: Mail.ReadWrite (Application)
XCHG_TENANT_ID=00000000-0000-0000-0000-000000000000
XCHG_CLIENT_ID=00000000-0000-0000-0000-000000000000
XCHG_CLIENT_SECRET=dein-client-secret

# UPN oder E-Mail-Adresse des Postfachs
XCHG_USER=dmarc@domain.com

# Ordner, kommagetrennt (optional, Standard: Inbox)
# Well-known: Inbox, Sent, Drafts, Deleted, Junk
XCHG_FOLDER=Inbox

# Papierkorb-Ordner für verarbeitete Mails (optional, Standard: deleteditems)
XCHG_TRASH_FOLDER=deleteditems
